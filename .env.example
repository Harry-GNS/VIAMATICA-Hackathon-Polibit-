# .env.example - copia este archivo a .env y completa las claves

# Clave de API de Groq
GROQ_API_KEY=

# Modelo por defecto (recomendado)
GROQ_MODEL=openai/gpt-oss-120b

# Modelos alternativos separados por comas
GROQ_MODEL_ALTERNATES=llama-3.3-70b-versatile,llama-3.1-8b-instant

# Forzar el uso de la API REST de Groq si el cliente oficial falla (0 o 1)
USE_GROQ_REST=0

# Servidor
PORT=5000
DEBUG=True

# Ruta a la base de datos SQLite
DATABASE_PATH=data/viamatica.db
